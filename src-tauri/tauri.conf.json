{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoiA",
  "mainBinaryName": "NoiA",
  "version": "3.6.2",
  "identifier": "com.noia.noia",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "noia2"
        ]
      }
    },
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": [
        "__TAURI_UPDATER_ENDPOINT_1__",
        "__TAURI_UPDATER_ENDPOINT_2__"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NoiA | 诺亚",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true,
        "devtools": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/windivert/WinDivert.dll": "WinDivert.dll",
      "resources/windivert/WinDivert64.sys": "WinDivert64.sys"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "installMode": "perMachine"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
