{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noia2-app",
  "mainBinaryName": "noia2-app",
  "version": "2.0.1",
  "identifier": "com.template.tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "noia2"
        ]
      }
    },
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": [
        "__TAURI_UPDATER_ENDPOINT_1__",
        "__TAURI_UPDATER_ENDPOINT_2__"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "noia2 永恒诺亚",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true,
        "visible": false
      },
      {
        "label": "dps_v2",
        "title": "DPS Meter V2",
        "url": "/dps_v2",
        "width": 320,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "dps_ping",
        "title": "DPS Ping",
        "url": "/dps_ping",
        "width": 150,
        "height": 20,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
