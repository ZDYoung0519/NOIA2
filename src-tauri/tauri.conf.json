{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noia2-app",
  "mainBinaryName": "noia2-app",
  "version": "0.2.2",
  "identifier": "com.template.tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": [
        "__TAURI_UPDATER_ENDPOINT_1__",
        "__TAURI_UPDATER_ENDPOINT_2__"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "noia2 永恒诺亚",
        "width": 1440,
        "height": 960,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
