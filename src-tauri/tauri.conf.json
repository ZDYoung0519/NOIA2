{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noia2",
  "version": "0.2.8",
  "identifier": "com.noia2.noia2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NOIA2 | 永恒诺亚",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "center": true,
        "label": "main",
        "visible": false
      },
      {
        "label": "splash",
        "url": "/splash",
        "width": 600,
        "height": 480,
        "decorations": false,
        "center": true
      },
      {
        "title": "DPS Meter",
        "width": 500,
        "height": 100,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "url": "/dps",
        "label": "dps",
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["bin/"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxNUEwRUJEREY5NTVENUMKUldSY1haWGZ2UTVhc2NhNTB4WDRrSHhzVWdoYld1TnhCZml4NnZsdE0xL1N6MFJIT3pvZ2w3QWoK",
      "endpoints": ["http://101.43.139.177:8866/download/latest.json"],
      "windows": {
        "installMode": "basicUi"
      },
      "dangerousInsecureTransportProtocol": true
    }
  }
}
