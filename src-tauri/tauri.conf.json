{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoiA",
  "mainBinaryName": "NoiA",
  "version": "3.8.3",
  "identifier": "com.noia.noia",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["noia2"]
      }
    },
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": ["__TAURI_UPDATER_ENDPOINT_1__", "__TAURI_UPDATER_ENDPOINT_2__"],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NoiA | 诺亚",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true,
        "devtools": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "NoiA",
        "url": "/splashscreen",
        "width": 640,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "center": true,
        "resizable": false,
        "shadow": true,
        "devtools": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/windivert/WinDivert.dll": "WinDivert.dll"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "installMode": "perMachine"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
